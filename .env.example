# Copiar a .env.local para desarrollo

# Proxy Vite (same-origin, sin CORS): activar y usar bases relativas en build dev
# VITE_USE_DEV_PROXY=true
# VITE_EMPLOYEE_API_BASE=/api-employee
# VITE_ORDER_API_BASE=/api-order
# ...

# APIs directas (por defecto en dev sin proxy)
VITE_EMPLOYEE_API_BASE=http://localhost:8080
VITE_ORDER_API_BASE=http://localhost:8083
VITE_TRANSPORT_API_BASE=http://localhost:8085
VITE_OSI_API_BASE=http://localhost:8086
VITE_PALES_SERVICE_API_BASE=http://localhost:8087
VITE_LOCATION_API_BASE=http://localhost:8088
VITE_INVENTORY_API_BASE=http://localhost:8089
VITE_RM_API_BASE=http://localhost:8090
VITE_CLIENT_API_BASE=http://localhost:8084

# Seguridad
VITE_AUTH_REGISTRATION_ENABLED=true
VITE_TOKEN_STORAGE=session

# Puertos Vite
# VITE_DEV_PORT=5173
