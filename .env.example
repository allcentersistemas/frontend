# Copiar a .env.local para desarrollo

# Monolito module-system (puerto 8080) — todas las APIs de negocio
VITE_SYSTEM_API_BASE=http://localhost:8080

# Biesse / escaneo OSI (puerto 8086)
VITE_OSI_API_BASE=http://localhost:8086

# Proxy Vite (same-origin): activar y usar bases relativas
# VITE_USE_DEV_PROXY=true
# VITE_SYSTEM_API_BASE=/api-system
# VITE_OSI_API_BASE=/api-biesse

# Seguridad
VITE_AUTH_REGISTRATION_ENABLED=true
VITE_TOKEN_STORAGE=session

# VITE_DEV_PORT=5173
